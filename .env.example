# ==============================================================================
# ZEE-INDEX CONFIGURATION TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION SETTINGS
# ------------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# Min 32 characters for security
NEXTAUTH_SECRET="generate-a-secure-random-string-that-is-32-chars-long"
SHARE_SECRET_KEY="generate-another-secure-random-string-32-chars-long"

ADMIN_EMAILS="admin@example.com"
ADMIN_PASSWORD="secure-password"

# ------------------------------------------------------------------------------
# 2. STORAGE CONFIGURATION
# ------------------------------------------------------------------------------
STORAGE_PROVIDER="google-drive"

# Optional: Can be configured via /setup (Stored in Redis)
NEXT_PUBLIC_ROOT_FOLDER_ID=""
NEXT_PUBLIC_ROOT_FOLDER_NAME="Home"

# JSON array of folder IDs to be hidden from public view
# Example: '["id1", "id2"]'
PRIVATE_FOLDER_IDS='[]'

# ------------------------------------------------------------------------------
# 3. GOOGLE DRIVE CREDENTIALS
# ------------------------------------------------------------------------------
# If left blank, use the Setup Wizard in the browser
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""

# ------------------------------------------------------------------------------
# 4. LIMITS & MONITORING
# ------------------------------------------------------------------------------
STORAGE_LIMIT_GB=15
STORAGE_WARNING_THRESHOLD=0.90
CRON_SECRET="generate-random-string-for-cron-protection"

# ------------------------------------------------------------------------------
# 5. EXTERNAL SERVICES
# ------------------------------------------------------------------------------
TMDB_API_KEY="your-tmdb-api-key"

# Email Configuration (Optional)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="Zee Index <no-reply@example.com>"

# ------------------------------------------------------------------------------
# 6. BUILD & VALIDATION
# ------------------------------------------------------------------------------
SKIP_ENV_VALIDATION=false
# Set to true to enable bundle analyzer during build
ANALYZE=false

# ------------------------------------------------------------------------------
# 7. DATABASE URL (PostgreSQL)
# ------------------------------------------------------------------------------
# For local development with Docker:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=zee_index
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"

# For production, use your managed PostgreSQL connection string:
# DATABASE_URL="postgresql://user:password@host:5432/zee_index?schema=public&sslmode=require"

# ------------------------------------------------------------------------------
# 8. CACHING & RATE LIMITING (Redis)
# ------------------------------------------------------------------------------
# Optional: Recommended for caching in production
# REDIS_URL="redis://localhost:6379"

# Optional: REST-based Redis for Edge runtime rate limiting (Upstash/Vercel KV)
# KV_REST_API_URL="https://your-rest-endpoint"
# KV_REST_API_TOKEN="your-rest-token"
# Alternative env names:
# UPSTASH_REDIS_REST_URL="https://your-rest-endpoint"
# UPSTASH_REDIS_REST_TOKEN="your-rest-token"

# ------------------------------------------------------------------------------
# 9. DEPLOYMENT & INFRASTRUCTURE (Optional)
# ------------------------------------------------------------------------------
# DUCKDNS_DOMAIN="your-subdomain"
# DUCKDNS_TOKEN="your-token"
